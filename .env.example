# Modele de configuration par-machine. Copier en `.env` et adapter :
#
#   cp .env.example .env
#
# `.env` est dans .gitignore (valeurs propres a chaque machine, comme
# workspaces.json). Charge par lua/env.lua ; les cles absentes retombent sur les
# defauts definis dans ce module. Voir VIBE_TLS_SETUP.md.

# Nom du domaine mux TLS cote client.
VIBE_DOMAIN=vibe

# IP de la machine vibe (le nom court WS871674 ne resout pas toujours hors interne).
VIBE_ADDR=10.91.16.171

# Port d'ecoute TLS du wezterm-mux-server sur vibe.
VIBE_TLS_PORT=8131
